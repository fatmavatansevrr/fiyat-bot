# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control

# --- Trendyol ---
TRENDYOL_EMAIL=your_email@example.com
TRENDYOL_PASSWORD=your_password

# --- Amazon TR ---
AMAZON_EMAIL=your_email@example.com
AMAZON_PASSWORD=your_password

# --- Migros ---
MIGROS_EMAIL=your_email@example.com
MIGROS_PASSWORD=your_password

# --- CarrefourSA ---
CARREFOUR_EMAIL=your_email@example.com
CARREFOUR_PASSWORD=your_password

# --- Gurmar ---
GURMAR_EMAIL=your_email@example.com
GURMAR_PASSWORD=your_password

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- Delivery address (Izmir) ---
DELIVERY_ADDRESS=Güzelyalı Mah. ... Izmir
DELIVERY_CITY=İzmir
DELIVERY_DISTRICT=Konak

# --- Agent settings ---
DISCOUNT_THRESHOLD=25
ALERT_COOLDOWN_HOURS=24
